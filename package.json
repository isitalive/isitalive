{
  "name": "isitalive",
  "version": "0.7.2",
  "license": "AGPL-3.0-only",
  "description": "Lightning-fast dependency health checker — is this open-source project safe to depend on?",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "npx tsx --import ./scripts/register-md.mjs scripts/build-static.ts",
    "predeploy": "npm run build",
    "deploy": "wrangler deploy",
    "types:generate": "wrangler types worker-configuration.d.ts",
    "types:check": "wrangler types worker-configuration.d.ts --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fuzz": "FC_NUM_RUNS=10000 vitest run"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@fast-check/vitest": "^0.3.0",
    "fast-check": "^4.6.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.5.0"
  }
}
