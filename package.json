{
  "name": "isitalive",
  "version": "0.14.0",
  "license": "AGPL-3.0-only",
  "description": "Maintenance-risk signals for open-source dependencies and AI agents",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "npx tsx --import ./scripts/register-md.mjs scripts/build-static.ts",
    "d1:migrations:check": "node scripts/check-d1-migrations.mjs",
    "check:deploy": "npm test && npx tsc --noEmit && npm run types:check && npm run d1:migrations:check",
    "predeploy": "npm run check:deploy && npm run build",
    "deploy": "wrangler deploy",
    "types:generate": "wrangler types worker-configuration.d.ts",
    "types:check": "wrangler types worker-configuration.d.ts --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fuzz": "FC_NUM_RUNS=10000 vitest run"
  },
  "dependencies": {
    "@interlynk-io/purl-js": "^1.0.3",
    "@yarnpkg/lockfile": "^1.1.0",
    "hono": "^4.12.25",
    "smol-toml": "^1.7.0",
    "workers-og": "^0.0.27",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.4.1",
    "@types/node": "^25.9.1",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.97.0"
  }
}
